Options -Indexes

# Route all requests through the public/ directory
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ /public/$1 [L]
</IfModule>

# Deny direct access to sensitive directories
<FilesMatch "^(config|src|sql|shared-auth|scripts|vendor)">
    Deny from all
</FilesMatch>
